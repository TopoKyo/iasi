rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      // User Email from runtime: chinchuarchibo@gmail.com
      return isVerified() && (
        request.auth.token.email == 'chinchuarchibo@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Catalog Item
    function isValidCatalogItem(data) {
      return data.keys().hasAll(['name', 'category', 'tag', 'image', 'specs', 'createdAt', 'updatedAt', 'createdBy'])
        && data.name is string && data.name.size() <= 200
        && data.category is string && data.category.size() <= 50
        && data.tag is string && data.tag.size() <= 50
        && data.image is string && data.image.size() <= 500
        && data.specs is list && data.specs.size() <= 10
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && data.createdBy == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Catalog Collection
    match /catalog/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCatalogItem(incoming());
      allow update: if isAdmin() 
        && incoming().name is string && incoming().name.size() <= 200
        && incoming().category is string && incoming().category.size() <= 50
        && incoming().tag is string && incoming().tag.size() <= 50
        && incoming().image is string && incoming().image.size() <= 500
        && incoming().specs is list && incoming().specs.size() <= 10
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().createdBy == existing().createdBy
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'tag', 'image', 'specs', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() 
        && incoming().keys().hasAll(['title', 'description', 'coverImage', 'carouselImages', 'createdAt', 'updatedAt', 'createdBy'])
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().description is string && incoming().description.size() <= 2000
        && incoming().coverImage is string && incoming().coverImage.size() <= 500
        && incoming().carouselImages is list && incoming().carouselImages.size() <= 20
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().createdBy == request.auth.uid;
      allow update: if isAdmin()
        && (incoming().title is string && incoming().title.size() <= 200)
        && (incoming().description is string && incoming().description.size() <= 2000)
        && (incoming().coverImage is string && incoming().coverImage.size() <= 500)
        && (incoming().carouselImages is list && incoming().carouselImages.size() <= 20)
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().createdBy == existing().createdBy;
      allow delete: if isAdmin();
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isVerified() && (request.auth.uid == adminId || isAdmin());
      allow write: if false; // Only manageable via console or higher-level logic
    }
  }
}
